{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "GROQ_API_KEY",
        "SMTP_URL",
        "CONTACT_EMAIL_TO",
        "NEXT_PUBLIC_DOCSYNC_SERVER_URL",
        "SKIP_ENV_VALIDATION"
      ]
    },
    "dev": { "cache": false, "persistent": true },
    "clean": { "cache": false },
    "typecheck": {}
  }
}

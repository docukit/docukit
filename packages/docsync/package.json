{
  "name": "@docukit/docsync",
  "version": "0.3.0-alpha.2",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "homepage": "https://docukit.dev/docsync",
  "repository": {
    "type": "git",
    "url": "https://github.com/docukit/docukit.git",
    "directory": "packages/docsync"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf .next node_modules .turbo dist tsconfig.build.tsbuildinfo || rmdir /s /q .next node_modules .turbo dist tsconfig.build.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "exports": {
    ".": {
      "vitest": "./src/exports/shared.ts",
      "types": "./dist/src/exports/shared.d.ts",
      "default": "./dist/src/exports/shared.js"
    },
    "./*": {
      "vitest": "./src/exports/*.ts",
      "types": "./dist/src/exports/*.d.ts",
      "default": "./dist/src/exports/*.js"
    }
  },
  "dependencies": {
    "@docukit/docnode": "workspace:*",
    "idb": "^8.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "keywords": [
    "sync",
    "sync engine",
    "real-time",
    "collaborative",
    "collaboration",
    "rtc",
    "conflict-resolution",
    "CRDT",
    "OT",
    "Operational Transformation",
    "document",
    "local-first",
    "offline-first"
  ]
}

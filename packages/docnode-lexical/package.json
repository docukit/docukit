{
  "name": "@docukit/docnode-lexical",
  "version": "0.3.1",
  "type": "module",
  "license": "MIT",
  "homepage": "https://docukit.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/docukit/docukit.git",
    "directory": "packages/docnode-lexical"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf node_modules .turbo dist tsconfig.build.tsbuildinfo || rmdir /s /q node_modules .turbo dist tsconfig.build.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "vitest": "./src/exports/index.ts",
      "types": "./dist/src/exports/index.d.ts",
      "default": "./dist/src/exports/index.js"
    },
    "./*": {
      "vitest": [
        "./src/exports/*.ts",
        "./src/exports/*.tsx"
      ],
      "types": "./dist/src/exports/*.d.ts",
      "default": "./dist/src/exports/*.js"
    }
  },
  "dependencies": {
    "@docukit/docnode": "workspace:*"
  },
  "peerDependencies": {
    "@lexical/react": ">=0.38.2",
    "@lexical/selection": ">=0.38.2",
    "lexical": ">=0.38.2",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@lexical/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lexical/react": "0.45.0",
    "@lexical/selection": "0.45.0",
    "@types/react": "^19.0.0",
    "lexical": "0.45.0"
  },
  "keywords": [
    "lexical",
    "editor",
    "rte",
    "rich text",
    "real-time",
    "collaborative",
    "collaboration",
    "rtc",
    "conflict-resolution",
    "CRDT",
    "OT",
    "Operational Transformation",
    "local-first",
    "offline-first"
  ]
}
